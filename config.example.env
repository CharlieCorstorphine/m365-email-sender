# ---------------------------------------------------------------------------
# Copy this file to  config.env  and fill in the FAST-PATH values below.
# (config.env can hold sign-in details — never commit it, email it, or put it in
#  a shared/public folder. See the two SETUP guides.)
# ---------------------------------------------------------------------------

# =========================================================================
# FAST PATH (the default — this is all most people need)
# =========================================================================

# --- Microsoft 365 (sign in as yourself) — see SETUP-microsoft-365.md ---
# CLIENT_ID comes from a one-time app registration (no secret, no admin consent).
CLIENT_ID=00000000-0000-0000-0000-000000000000

# TENANT_ID is OPTIONAL on the fast path. Leave it blank to use "organizations",
# which works for any work/school Microsoft 365 account. Fill it in only if your
# admin tells you sign-in must be tenant-specific.
TENANT_ID=

# A label for this batch. Change it for each new campaign so the "don't email the
# same person twice" protection scopes to this campaign only.
CAMPAIGN_ID=my-first-campaign

# --- Google Sheet (published to web as CSV) — see SETUP-google-sheet.md ---
# In your Sheet: File > Share > Publish to web > pick the tab > CSV > Publish.
# Paste that link here. It is NOT the normal sheet URL — it ends in output=csv.
CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXXXXXX/pub?gid=0&single=true&output=csv

# --- Optional extra targeting filter (add-on to the in-sheet Send column) ---
# Leave both blank to rely purely on the sheet's Send column. When set, ONLY rows
# where the named column equals this value are emailed (AND they must still have
# Send marked). Example: only email rows where City = Houston.
FILTER_COLUMN=
FILTER_VALUE=

# Where to cache your Microsoft sign-in so you're not asked every run.
# Optional — defaults to token_cache.json next to the script.
# TOKEN_CACHE=/full/path/to/token_cache.json


# =========================================================================
# OPTIONAL / ADVANCED (only for m365_sender_advanced.py — ignore on the fast path)
# Use these if you chose app-only auth + write-back into the sheet. See the
# appendices in the two SETUP guides. Leave commented out otherwise.
# =========================================================================
# CLIENT_SECRET=your-client-secret-value-here      # app-only auth (needs admin consent)
# SENDER_UPN=you@yourcompany.com                    # mailbox to send FROM (app-only)
# GOOGLE_SERVICE_ACCOUNT_JSON=/full/path/to/service-account-key.json
# SHEET_ID=your-sheet-id-or-full-url-here
# SHEET_TAB=Contacts
